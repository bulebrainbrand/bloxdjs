{
    "compilerOptions": {
        "target": "esnext",
        "moduleDetection": "force",
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "types": [],
        "strict": true,
        "noUnusedLocals": false,
        "declaration": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true,
        "composite": true,
    },
    "include": [
        "./src**/*.ts"
    ],
}